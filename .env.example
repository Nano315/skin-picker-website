# Copy to .env.local for local development (already gitignored).
# In production, these are set in the Vercel project → Settings → Environment Variables.
#
# All NEXT_PUBLIC_* vars are INLINED INTO THE CLIENT BUNDLE at build time.
# Only put values that are safe to ship publicly (Aptabase app key, public endpoints).

# Aptabase Analytics (https://aptabase.com)
# App key from the Aptabase dashboard for the website app. Leave empty to
# disable telemetry entirely (useful in dev / preview deployments).
NEXT_PUBLIC_APTABASE_APP_KEY=
# Optional: self-hosted Aptabase instance (e.g. https://aptabase.example.com).
# Leave empty to use Aptabase Cloud.
NEXT_PUBLIC_APTABASE_HOST=
